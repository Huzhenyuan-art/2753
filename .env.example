# ============================================
# 环境变量配置模板 - 请复制为 .env 后修改
# 注意：.env 文件已加入 .gitignore，请勿提交到仓库
# ============================================

# ---------- 通用配置 ----------
COMPOSE_PROJECT_NAME=user-manager
APP_ENV=production
TZ=Asia/Shanghai

# ---------- MySQL 数据库 ----------
MYSQL_IMAGE=mysql:8.0
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change_this_strong_password
MYSQL_DATABASE=user_management
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci

# 宿主机映射端口
MYSQL_PUBLISH_PORT=12753

# ---------- Backend 后端 ----------
BACKEND_SERVER_PORT=8080
BACKEND_PUBLISH_PORT=22753

# Spring 数据源
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/user_management?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_this_strong_password

# JWT 密钥 - 生产环境请使用强随机密钥
JWT_SECRET=please_change_this_to_a_very_long_random_string_at_least_256_bits_long_for_production
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# 文件上传目录
FILE_UPLOAD_DIR=/app/uploads/avatars

# Spring Profile
SPRING_PROFILES_ACTIVE=production

# ---------- Frontend 前端 ----------
FRONTEND_PUBLISH_PORT=32753
VITE_API_BASE_URL=/api
